# OpenRouter (multi-model LLM)
OPENROUTER_API_KEY=sk-or-...

# Bright Data (SERP + Web Scraping)
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_SERP_ZONE=serp_api
BRIGHT_DATA_UNLOCKER_ZONE=web_unlocker1

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini (featured image generation)
GEMINI_API_KEY=

# WordPress (optional - per-site config can override)
WP_SITE_URL=
WP_USERNAME=
WP_APP_PASSWORD=

# ScreenshotOne (vendor screenshots, optional - falls back to Bright Data)
SCREENSHOTONE_API_KEY=

# Vercel Cron Secret
CRON_SECRET=
